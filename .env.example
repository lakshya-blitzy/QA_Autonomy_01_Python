# =============================================================================
# Environment configuration template for the secure Node.js/Express app.
# =============================================================================
# Copy this file to `.env` and fill in real values for your deployment:
#
#     cp .env.example .env
#
# NEVER commit `.env`. It is git-ignored (see .gitignore: `.env` and `.env.*`
# are ignored, while this secret-free `.env.example` template is explicitly
# re-included). No secrets belong in this template â€” placeholders only.
#
# These variables are read directly from `process.env` by `config/security.js`,
# which is the single source of truth for the app's security configuration.
# The variable names below MUST match that module exactly:
#     PORT, ALLOWED_ORIGINS, TLS_KEY_PATH, TLS_CERT_PATH,
#     RATE_LIMIT_WINDOW_MS, RATE_LIMIT_MAX
# =============================================================================


# -----------------------------------------------------------------------------
# PORT  (R4 â€” HTTPS support)
# -----------------------------------------------------------------------------
# TCP port that the HTTPS server binds to. Consumed by src/server.js via
# config/security.js -> `port`. If unset, config/security.js falls back to
# 8443. Prefer a non-privileged port (> 1024) unless the process has been
# granted the capability to bind low ports.
PORT=8443


# -----------------------------------------------------------------------------
# ALLOWED_ORIGINS  (R7 â€” proper CORS policy)
# -----------------------------------------------------------------------------
# Comma-separated allowlist of EXACT origins permitted to make cross-origin
# requests. Include the scheme (https) and, if non-standard, the port.
# NEVER use `*` â€” a wildcard is stripped defensively by config/security.js and
# must never be relied upon, and it must never be combined with credentials.
# Leave empty to deny all cross-origin requests (secure default: same-origin
# only).
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com


# -----------------------------------------------------------------------------
# TLS_KEY_PATH  (R4 â€” HTTPS support)
# -----------------------------------------------------------------------------
# Filesystem path to the PEM-encoded TLS private key used by
# https.createServer (src/server.js) via config/security.js -> `tls.keyPath`.
# The key MATERIAL is provisioned out-of-band and is NEVER committed
# (`*.pem`, `*.key`, and `/certs` are git-ignored). This is a PATH only.
TLS_KEY_PATH=./certs/key.pem


# -----------------------------------------------------------------------------
# TLS_CERT_PATH  (R4 â€” HTTPS support)
# -----------------------------------------------------------------------------
# Filesystem path to the PEM-encoded TLS certificate (or full chain) used by
# https.createServer (src/server.js) via config/security.js -> `tls.certPath`.
# Provisioned out-of-band and NEVER committed alongside the repository. This is
# a PATH only â€” no certificate material belongs in this file.
TLS_CERT_PATH=./certs/cert.pem


# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS  (R3 â€” rate limiting)
# -----------------------------------------------------------------------------
# Duration of the fixed rate-limit window, in milliseconds, enforced by
# express-rate-limit via config/security.js -> `rateLimit.windowMs`. Default is
# 900000 ms (15 minutes). Must be a positive integer; non-numeric or non-
# positive values fall back to the 900000 default.
RATE_LIMIT_WINDOW_MS=900000


# -----------------------------------------------------------------------------
# RATE_LIMIT_MAX  (R3 â€” rate limiting)
# -----------------------------------------------------------------------------
# Maximum number of requests a single client may make within one window before
# receiving HTTP 429 (Too Many Requests). Maps to config/security.js ->
# `rateLimit.limit`. Default is 100. Must be a positive integer; non-numeric or
# non-positive values fall back to the 100 default.
RATE_LIMIT_MAX=100
